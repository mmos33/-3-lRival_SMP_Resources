{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:display_context",
    "cases": [
      {
        "when": [
          "gui",
          "ground",
          "fixed",
          "on_shelf"
        ],
        "model": {
          "type": "minecraft:model",
          "model": "minecraft:item/t_blue"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:condition",
      "property": "minecraft:using_item",
      "on_true": {
        "type": "minecraft:model",
        "model": "minecraft:item/t_blue_throwing"
      },
      "on_false": {
        "type": "minecraft:model",
        "model": "minecraft:item/t_blue_in_hand"
      }
    }
  }
}